generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                 @id @default(autoincrement())
  email             String              @unique
  username          String              @unique
  password_hash     String
  full_name         String?
  avatar_url        String?
  email_verified    Boolean             @default(false)
  email_verified_at DateTime?
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt

  applications      Application[]
  rankCenters       RankCenter[]
  apiKeys           ApiKey[]
  passwordResets    PasswordReset[]
  refreshTokens     RefreshToken[]
  emailVerification EmailVerification?
}

model ApiKey {
  id             Int       @id @default(autoincrement())
  user_id        Int
  type           String
  name           String?
  encrypted_key  String
  key_prefix     String
  scopes_json    String?
  expires_at     DateTime?
  usage_count    Int       @default(0)
  last_used      DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  is_active      Boolean   @default(true)

  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([type])
}

model Application {
  id              String                  @id @default(uuid())
  user_id         Int
  name            String
  description     String?
  group_id        String
  target_role     String
  pass_score      Int                     @default(70)
  primary_color   String                  @default("#ff7e6d")
  secondary_color String                  @default("#102437")
  questions_json  String                  @db.LongText
  style_json      String?                 @db.LongText
  created_at      DateTime                @default(now())
  updated_at      DateTime                @updatedAt

  user            User                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  submissions     ApplicationSubmission[]

  @@index([user_id])
  @@index([group_id])
}

model RankCenter {
  id           String   @id @default(uuid())
  user_id      Int
  name         String
  group_id     String
  universe_id  String?
  ranks_json   String   @db.LongText
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([group_id])
}

model ApplicationSubmission {
  id               String      @id @default(uuid())
  application_id   String
  roblox_user_id   String
  membership_id    String?
  answers_json     String      @db.LongText
  score            Float
  max_score        Float
  passed           Boolean
  feedback         String?     @db.Text
  breakdown_json   String?     @db.LongText
  promotion_status String?
  submitted_at     DateTime    @default(now())

  application      Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@index([application_id])
  @@index([roblox_user_id])
}

model PasswordReset {
  id         String   @id @default(uuid())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
}

model EmailVerification {
  id         String   @id @default(uuid())
  user_id    Int      @unique
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
}
